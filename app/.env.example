# SafeNudge frontend — local dev environment
#
# Copy to .env and tweak as needed. The dev server falls back to these same
# values when no .env is present (see app/src/utils/constants.ts), so most
# devs won't need a .env at all. Production builds (Vercel) require every
# var to be set explicitly — the build throws otherwise.

# Program ID of the deployed SafeNudge Anchor program on the target cluster.
VITE_PROGRAM_ID=88vmqe9yLF4mYtamaX53Cwg66GaxzyH391bQudcA8FcB

# USDC mint address on the target cluster. The default is Circle's official
# devnet USDC mint — funded via https://faucet.circle.com.
VITE_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# Solana RPC endpoint. The default public devnet endpoint is rate-limited;
# swap for a Helius/Triton/QuickNode URL if you hit throttling during testing.
VITE_SOLANA_RPC_URL=https://api.devnet.solana.com

# PostHog project API key (phc_...). When unset, analytics are a no-op —
# local dev runs without sending events. Set in Vercel for production.
VITE_POSTHOG_KEY=
# Optional. Defaults to the PostHog EU cloud host (LGPD-friendly).
VITE_POSTHOG_HOST=https://eu.i.posthog.com
